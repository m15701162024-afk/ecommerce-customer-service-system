# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommerce_auth
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here
DB_POOL_MAX=20
DB_POOL_MIN=5

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration (Generate a secure 256-bit key)
JWT_SECRET=your_256_bit_secret_key_here_generate_with_openssl_rand_base64_32
JWT_EXPIRATION=86400000

# Server Configuration
SERVER_PORT=8083

# Logging
LOG_LEVEL=INFO
SHOW_SQL=false